# Copy to .env and adjust. Every value has a sensible default — override only what you need.

# Performance (CPU-friendly defaults)
ANALYSIS_FPS=2                 # frames analysed per second
MAX_FRAME_WIDTH=960            # downscale frames wider than this
MAX_CONCURRENT_SESSIONS=2      # simultaneous analyses on one machine
JPEG_QUALITY=80

# API
CORS_ORIGINS=*                 # in production: https://your-frontend.vercel.app

# Module tuning
FACE_THRESHOLD=0.4             # cosine distance; lower = stricter match
ATTENDANCE_GAP_MIN=5           # minutes away before a new check-in is logged
PPE_VIOLATION_PREFIXES=no,without
PPE_NEUTRAL_CLASSES=person          # detected but excluded from compliance math
PPE_CONFIDENCE=0.4
VIOLATION_COOLDOWN_S=10
IDLE_SECONDS=10                # stillness before a worker counts as idle
OCR_LANGS=en

# ANPR (one event per vehicle visit; reads are accumulated and the best one wins)
PLATE_COOLDOWN_S=60            # same plate seen again within this window = same visit, not re-logged
PLATE_MIN_CHARS=3              # reject shorter reads
PLATE_MAX_CHARS=10             # reject longer (garbage) reads
PLATE_OCR_MIN_CONF=0.3         # drop OCR fragments below this confidence
PLATE_OCR_UPSCALE_W=120        # plate crops narrower than this are 2x-upscaled before OCR
PLATE_MATCH_RATIO=0.6          # text similarity for two reads to count as the same plate
PLATE_TRACK_MAX_DIST=0.2       # spatial track match limit, as a fraction of frame width
PLATE_TRACK_TTL_S=3            # plate unseen for this long = visit over, event logged
PLATE_CONFIRM_READS=2          # reads needed before logging a vehicle that stays in view
PLATE_SINGLE_READ_CONF=0.5     # a visit backed by a single read needs at least this confidence
PLATE_LOG_MAX_WAIT_S=10        # vehicle still in view after this long gets logged anyway
PLATE_THUMB_W=160              # width of the plate thumbnail stored with each event

# Paths (only override when not using the defaults baked into the image)
# MODELS_DIR=/app/models
# DATA_DIR=/app/data
# DEMO_DIR=/app/demo_videos
# FACES_DIR=/app/faces_db

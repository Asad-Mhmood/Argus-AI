# Copy to .env and adjust. Every value has a sensible default — override only what you need.

# Performance (CPU-friendly defaults)
ANALYSIS_FPS=2                 # frames analysed per second
MAX_FRAME_WIDTH=960            # downscale frames wider than this
MAX_CONCURRENT_SESSIONS=2      # simultaneous analyses on one machine
JPEG_QUALITY=80

# API
CORS_ORIGINS=*                 # in production: https://your-frontend.vercel.app

# Module tuning
FACE_THRESHOLD=0.4             # cosine distance; lower = stricter match
ATTENDANCE_GAP_MIN=5           # minutes away before a new check-in is logged
UNKNOWN_FACE_COOLDOWN_S=30     # dedupe window for unknown-face events
PPE_VIOLATION_PREFIXES=no,without
PPE_NEUTRAL_CLASSES=person          # detected but excluded from compliance math
PPE_CONFIDENCE=0.4
VIOLATION_COOLDOWN_S=10
IDLE_SECONDS=10                # stillness before a worker counts as idle
PLATE_COOLDOWN_S=60            # dedupe window for the same plate
OCR_LANGS=en

# Paths (only override when not using the defaults baked into the image)
# MODELS_DIR=/app/models
# DATA_DIR=/app/data
# DEMO_DIR=/app/demo_videos
# FACES_DIR=/app/faces_db
